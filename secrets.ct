import { projectSecrets } from "github.com/cloudticon/k8s@master";

type InfisicalSecretsArgs = Omit<
  Parameters<typeof projectSecrets>[0],
  "name"
> & { name?: string };

export const infisicalSecrets = (args: InfisicalSecretsArgs) => {
  return projectSecrets({
    name: args.name ?? "main",
    ...args,
  });
};
